pragma solidity ^0.8.20;

contract IdentityRegistry {

    struct User {
        string did; // decentralized identifier
        bool exists;
    }

    mapping(address => User) public users;

    event UserRegistered(address indexed user, string did);

    function register(string memory _did) public {
        require(!users[msg.sender].exists, "Already registered");

        users[msg.sender] = User({
            did: _did,
            exists: true
        });

        emit UserRegistered(msg.sender, _did);
    }

    function isRegistered(address _user) public view returns (bool) {
        return users[_user].exists;
    }
}
